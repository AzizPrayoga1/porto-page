{
  "name": "portfolio-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "astro dev",
    "build:frontend": "astro build",
    "preview:frontend": "astro preview",
    "dev:backend": "wrangler dev worker/index.ts",
    "deploy:backend": "wrangler deploy worker/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply portfolio-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply portfolio-db --remote"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "@astrojs/tailwind": "^6.0.0",
    "astro": "^4.16.0",
    "drizzle-orm": "^0.30.10",
    "framer-motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.21.4",
    "typescript": "^5.4.5",
    "wrangler": "^3.57.1"
  }
}
