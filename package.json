{
  "name": "portfolio-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "astro build",
    "dev:frontend": "astro dev",
    "build:frontend": "astro build",
    "preview:frontend": "astro preview",
    "dev:backend": "wrangler dev --config dist/server/wrangler.json",
    "deploy": "astro build && wrangler deploy --config dist/server/wrangler.json",
    "deploy:backend": "wrangler deploy --config dist/server/wrangler.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply portfolio-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply portfolio-db --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.4",
    "@astrojs/react": "^6.0.1",
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.3",
    "drizzle-orm": "^0.30.10",
    "framer-motion": "^12.42.2",
    "headroom-ai": "^0.22.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.21.4",
    "typescript": "^5.4.5",
    "wrangler": "^4.113.0"
  }
}
