---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import About from '../components/About';
import Timeline from '../components/Timeline';
---

<Layout title="About | dev&sec.">
  <Navbar client:load />

  <main class="flex-grow max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <div class="mb-10 text-center md:text-left">
      <h1 class="text-4xl font-extrabold tracking-tight">Tentang Saya</h1>
      <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">
        Informasi detail seputar keahlian, latar belakang, dan riwayat profesional saya.
      </p>
    </div>

    <About />

    <div class="my-8"></div>

    <Timeline client:visible />
  </main>

  <Footer client:visible />
</Layout>
