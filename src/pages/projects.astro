---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ProjectCard from '../components/ProjectCard';

const API_URL = 'http://localhost:8787';
let projects = [];
let errorMsg = null;

try {
  const response = await fetch(`${API_URL}/api/projects`);
  if (response.ok) {
    projects = await response.json();
  } else {
    errorMsg = `Gagal memuat proyek: HTTP ${response.status}`;
  }
} catch (e) {
  errorMsg = "Gagal menghubungi backend API lokal (Worker belum berjalan). Menggunakan data cadangan.";
}

// Fallback mock projects list
const fallbackProjects = [
  {
    id: "repo-1",
    name: "auto-portfolio",
    description: "Self-updating developer & CTF portfolio platform on Cloudflare.",
    language: "TypeScript",
    topics: ["astro", "cloudflare", "drizzle", "react"],
    stars: 12,
    forks: 2,
    url: "https://github.com/octocat/auto-portfolio",
    isPinned: true
  },
  {
    id: "repo-2",
    name: "ctf-exploit-kit",
    description: "Collection of automated exploit scripts for various CTF categories.",
    language: "Python",
    topics: ["ctf", "exploit", "pwn", "security"],
    stars: 45,
    forks: 8,
    url: "https://github.com/octocat/ctf-exploit-kit",
    isPinned: true
  },
  {
    id: "repo-3",
    name: "dotfiles",
    description: "My personal developer workspace configs for Neovim and Tmux.",
    language: "Lua",
    topics: ["neovim", "tmux", "dotfiles"],
    stars: 3,
    forks: 0,
    url: "https://github.com/octocat/dotfiles",
    isPinned: false
  }
];

const displayProjects = projects.length > 0 ? projects : fallbackProjects;
---

<Layout title="Projects | dev&sec.">
  <Navbar client:load />

  <main class="flex-grow max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <div class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight">Proyek GitHub</h1>
      <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">
        Daftar proyek open-source yang ditarik secara otomatis dari API GitHub.
      </p>
      {errorMsg && (
        <div class="mt-4 p-3 rounded-lg text-xs bg-amber-500/10 text-amber-700 dark:text-amber-400 border border-amber-500/20">
          ⚠️ {errorMsg}
        </div>
      )}
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {displayProjects.map((p: any) => (
        <ProjectCard
          name={p.name}
          description={p.description}
          language={p.language}
          topics={p.topics}
          stars={p.stars}
          forks={p.forks || 0}
          url={p.url}
          isPinned={p.isPinned}
        />
      ))}
    </div>
  </main>

  <Footer />
</Layout>
