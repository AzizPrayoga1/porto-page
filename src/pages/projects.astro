---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ProjectCard from '../components/ProjectCard';
import { drizzle } from 'drizzle-orm/d1';
import * as schema from '../db/schema';
import { eq } from 'drizzle-orm';
import { env } from 'cloudflare:workers';

const db = env?.DB ? drizzle(env.DB, { schema }) : null;

let projects: any[] = [];

if (db) {
  try {
    projects = await db.select().from(schema.projects).where(eq(schema.projects.isHidden, false));
  } catch (e) {
    // Fallback jika database belum tersambung / kosong
  }
}
---

<Layout title="Projects | dev&sec.">
  <Navbar client:load />

  <main class="flex-grow max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <div class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight">Proyek GitHub</h1>
      <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">
        Daftar proyek open-source yang ditarik secara otomatis dari API GitHub.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {displayProjects.map((p: any) => (
        <ProjectCard
          name={p.name}
          description={p.description}
          language={p.language}
          topics={p.topics}
          stars={p.stars}
          forks={p.forks || 0}
          url={p.url}
          isPinned={p.isPinned}
        />
      ))}
    </div>
  </main>

  <Footer />
</Layout>
