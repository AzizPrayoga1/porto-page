---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ProjectCard from '../components/ProjectCard';
import { drizzle } from 'drizzle-orm/d1';
import * as schema from '../db/schema';
import { eq } from 'drizzle-orm';
import { env } from 'cloudflare:workers';

const db = env?.DB ? drizzle(env.DB, { schema }) : null;

let projects: any[] = [];

if (db) {
  try {
    projects = await db.select().from(schema.projects).where(eq(schema.projects.isHidden, false));
  } catch (e) {
    // Graceful fallback
  }
}

// Fallback jika database masih kosong/belum di-migrate
const fallbackProjects = [
  {
    id: "repo-1",
    name: "auto-portfolio",
    description: "Self-updating developer & CTF portfolio platform on Cloudflare.",
    language: "TypeScript",
    topics: ["astro", "cloudflare", "drizzle", "react"],
    stars: 12,
    forks: 2,
    url: "https://github.com/octocat/auto-portfolio",
    isPinned: true
  },
  {
    id: "repo-2",
    name: "ctf-exploit-kit",
    description: "Collection of automated exploit scripts for various CTF categories.",
    language: "Python",
    topics: ["ctf", "exploit", "pwn", "security"],
    stars: 45,
    forks: 8,
    url: "https://github.com/octocat/ctf-exploit-kit",
    isPinned: true
  }
];

// Pastikan variabel displayProjects ini yang diekspor/dipakai di template
const displayProjects = projects.length > 0 ? projects : fallbackProjects;
---

<Layout title="Projects | dev&sec.">
  <Navbar client:load />
  <main class="flex-grow max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <h1 class="text-3xl font-bold mb-8">All Projects</h1>
    <div class="grid gap-6 md:grid-cols-2">
      {displayProjects.map((p: any) => (
        <ProjectCard
          name={p.name}
          description={p.description}
          language={p.language}
          topics={p.topics}
          stars={p.stars}
          forks={p.forks || 0}
          url={p.url}
          isPinned={p.isPinned}
        />
      ))}
    </div>
  </main>
  <Footer client:visible />
</Layout>