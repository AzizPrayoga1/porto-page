---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ProjectCard from '../components/ProjectCard';
import { drizzle } from 'drizzle-orm/d1';
import * as schema from '../db/schema';
import { eq } from 'drizzle-orm';

const runtime = Astro.locals.runtime;
const db = runtime?.env?.DB ? drizzle(runtime.env.DB, { schema }) : null;

let projects: any[] = [];

if (db) {
  try {
    projects = await db.select().from(schema.projects).where(eq(schema.projects.isHidden, false));
  } catch (e) {}
}

// Fallback mock projects list
const fallbackProjects = [
  {
    id: "repo-1",
    name: "auto-portfolio",
    description: "Self-updating developer & CTF portfolio platform on Cloudflare.",
    language: "TypeScript",
    topics: ["astro", "cloudflare", "drizzle", "react"],
    stars: 12,
    forks: 2,
    url: "https://github.com/octocat/auto-portfolio",
    isPinned: true
  },
  {
    id: "repo-2",
    name: "ctf-exploit-kit",
    description: "Collection of automated exploit scripts for various CTF categories.",
    language: "Python",
    topics: ["ctf", "exploit", "pwn", "security"],
    stars: 45,
    forks: 8,
    url: "https://github.com/octocat/ctf-exploit-kit",
    isPinned: true
  },
  {
    id: "repo-3",
    name: "dotfiles",
    description: "My personal developer workspace configs for Neovim and Tmux.",
    language: "Lua",
    topics: ["neovim", "tmux", "dotfiles"],
    stars: 3,
    forks: 0,
    url: "https://github.com/octocat/dotfiles",
    isPinned: false
  }
];

const displayProjects = projects.length > 0 ? projects : fallbackProjects;
---

<Layout title="Projects | dev&sec.">
  <Navbar client:load />

  <main class="flex-grow max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <div class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight">Proyek GitHub</h1>
      <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">
        Daftar proyek open-source yang ditarik secara otomatis dari API GitHub.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {displayProjects.map((p: any) => (
        <ProjectCard
          name={p.name}
          description={p.description}
          language={p.language}
          topics={p.topics}
          stars={p.stars}
          forks={p.forks || 0}
          url={p.url}
          isPinned={p.isPinned}
        />
      ))}
    </div>
  </main>

  <Footer />
</Layout>
