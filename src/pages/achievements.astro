---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import AchievementCard from '../components/AchievementCard';
import { drizzle } from 'drizzle-orm/d1';
import * as schema from '../db/schema';
import { gte } from 'drizzle-orm';
import { env } from 'cloudflare:workers';

const db = env?.DB ? drizzle(env.DB, { schema }) : null;

let achievements: any[] = [];
let rawRatingHistory: any[] = [];

if (db) {
  try {
    const [ctfList, history] = await Promise.all([
      db.select().from(schema.ctfAchievements),
      // Hanya ambil rating tahun 2026 ke atas dari D1
      db.select().from(schema.ctfRatingHistory).where(gte(schema.ctfRatingHistory.year, 2026))
    ]);
    achievements = ctfList;
    rawRatingHistory = history;
  } catch (e) {
    // Fallback
  }
}

// Pastikan hanya tahun >= 2026 yang ditampilkan
const ratingHistory = rawRatingHistory.filter((r: any) => r.year >= 2026);
---

<Layout title="Achievements | nvc.">
  <Navbar client:load />

  <main class="flex-grow max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <div class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight">Pencapaian CTF</h1>
      <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">
        Riwayat partisipasi kompetisi Capture The Flag (CTF) dan statistik rating dari CTFtime.
      </p>
    </div>

    {/* Grafik Rating CTFtime */}
    <div class="mb-12 p-6 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900">
      <h2 class="text-xl font-bold mb-4">Grafik Rating CTFtime (2026+)</h2>
      <div class="h-48 flex items-end justify-center gap-8 pt-6 pb-2 border-b border-zinc-200 dark:border-zinc-800">
        {ratingHistory.map((r: any) => (
          <div class="flex-1 max-w-[120px] flex flex-col items-center gap-2 h-full justify-end">
            <div
              class="w-full bg-emerald-500 hover:bg-emerald-400 transition-colors rounded-t relative group"
              style={`height: ${Math.min(100, Math.max(15, (r.ratingPoints / 200) * 100))}%`}
            >
              <span class="absolute -top-7 left-1/2 -translate-x-1/2 bg-zinc-800 text-white text-[10px] px-1.5 py-0.5 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
                Pts: {Math.round(r.ratingPoints * 100) / 100}
              </span>
            </div>
            <span class="text-xs text-zinc-500 font-semibold">{r.year}</span>
          </div>
        ))}
        {ratingHistory.length === 0 && (
          <span class="text-sm text-zinc-500 pb-16">Belum ada data rating 2026+ yang tersinkronisasi.</span>
        )}
      </div>
    </div>

    {/* List Event CTF */}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {achievements.map((a: any) => (
        <AchievementCard
          eventName={a.eventName}
          eventDate={a.eventDate}
          rank={a.rank}
          points={a.points}
          teamName={a.teamName || 'KuroCyber'}
        />
      ))}
    </div>
  </main>

  <Footer client:visible />
</Layout>