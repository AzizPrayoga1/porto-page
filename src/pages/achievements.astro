---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import AchievementCard from '../components/AchievementCard';

const API_URL = 'http://localhost:8787';
let achievements = [];
let errorMsg = null;

let stats = { ratingHistory: [{ year: 2026, ratingPoints: 145.63, countryRank: 10 }] };

try {
  const response = await fetch(`${API_URL}/api/achievements`);
  if (response.ok) {
    achievements = await response.json();
  } else {
    errorMsg = `Gagal memuat pencapaian: HTTP ${response.status}`;
  }
} catch (e) {
  errorMsg = "Gagal menghubungi backend API lokal (Worker belum berjalan). Menggunakan data cadangan.";
}

try {
  const statsRes = await fetch(`${API_URL}/api/stats`);
  if (statsRes.ok) {
    stats = await statsRes.json();
  }
} catch (e) {}

// Filter ratingHistory: we only show years with ratingPoints > 0 to match live CTFtime
const ratingHistory = (stats.ratingHistory || []).filter((r: any) => r.ratingPoints > 0);

// Fallback mock achievements list
const fallbackAchievements = [
  {
    id: "ctf-1",
    eventName: "Google CTF 2026",
    eventDate: new Date("2026-06-25").getTime(),
    rank: 42,
    points: 1550.5,
    teamName: "KuroCyber"
  },
  {
    id: "ctf-2",
    eventName: "DEF CON CTF 34 Quals",
    eventDate: new Date("2026-05-18").getTime(),
    rank: 18,
    points: 3400.0,
    teamName: "KuroCyber"
  },
  {
    id: "ctf-3",
    eventName: "InnoSec CTF 2026",
    eventDate: new Date("2026-07-10").getTime(),
    rank: 2,
    points: 420.0,
    teamName: "KuroCyber (Individu)"
  }
];

const displayAchievements = achievements.length > 0 ? achievements : fallbackAchievements;
---

<Layout title="Achievements | dev&sec.">
  <Navbar client:load />

  <main class="flex-grow max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <div class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight">Pencapaian CTF</h1>
      <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">
        Riwayat partisipasi kompetisi Capture The Flag (CTF) dan statistik rating dari CTFtime.
      </p>
      {errorMsg && (
        <div class="mt-4 p-3 rounded-lg text-xs bg-amber-500/10 text-amber-700 dark:text-amber-400 border border-amber-500/20">
          ⚠️ {errorMsg}
        </div>
      )}
    </div>

    {/* Simple rating chart / panel placeholder */}
    <div class="mb-12 p-6 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900">
      <h2 class="text-xl font-bold mb-4">Grafik Rating CTFtime (Tren Tahunan)</h2>
      <div class="h-48 flex items-end justify-center gap-8 pt-6 pb-2 border-b border-zinc-200 dark:border-zinc-800">
        {ratingHistory.map((r: any) => (
          <div class="flex-1 max-w-[120px] flex flex-col items-center gap-2 h-full justify-end">
            <div
              class="w-full bg-zinc-700 dark:bg-zinc-300 hover:bg-zinc-600 dark:hover:bg-zinc-400 transition-colors rounded-t relative group"
              style={`height: ${Math.min(100, Math.max(10, (r.ratingPoints / 150) * 100))}%`}
            >
              <span class="absolute -top-7 left-1/2 -translate-x-1/2 bg-zinc-800 text-white text-[10px] px-1.5 py-0.5 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">Pts: {Math.round(r.ratingPoints * 100) / 100}</span>
            </div>
            <span class="text-xs text-zinc-500 font-semibold">{r.year}</span>
          </div>
        ))}
        {ratingHistory.length === 0 && (
          <span class="text-sm text-zinc-500 pb-16">Belum ada data rating tahunan yang tersinkronisasi.</span>
        )}
      </div>
      <p class="mt-4 text-xs text-zinc-500 text-center">
        Grafik di atas dirender secara dinamis berdasarkan data rating tahunan yang berhasil disinkronisasi.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {displayAchievements.map((a: any) => (
        <AchievementCard
          eventName={a.eventName}
          eventDate={a.eventDate}
          rank={a.rank}
          points={a.points}
          teamName={a.teamName}
        />
      ))}
    </div>
  </main>

  <Footer />
</Layout>
